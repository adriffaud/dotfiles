[module/title]
type = internal/xwindow

format = <label>
format-background = ${colors.shade4}
format-foreground = ${colors.modulefg}
format-padding = 1

label = %title%
label-maxlen = 50

;;label-empty = Arch Linux
;;label-empty-foreground = #707880

#################

[module/i3]
;https://github.com/jaagr/polybar/wiki/Module:-i3
type = internal/i3

; Only show workspaces defined on the same output as the bar
;
; Useful if you want to show monitor specific workspaces
; on different bars
;
; Default: false
pin-workspaces = true
strip-wsnumbers = false
index-sort = false
enable-click = true
enable-scroll = true
wrapping-scroll = false
reverse-scroll = true

; Use fuzzy (partial) matching on labels when assigning
; icons to workspaces
; Example: code;ŌÖÜ will apply the icon to all workspaces
; containing 'code' in the label
; Default: false
fuzzy-match = false

ws-icon-0 = 1;’é¼
ws-icon-1 = 2;’äĪ
ws-icon-2 = 3;’äĀ
ws-icon-3 = 4;’åś
ws-icon-4 = 5;’å╝
ws-icon-5 = 6;’ĆĮ
ws-icon-6 = 7;’äē
ws-icon-7 = 8;’ü╝
ws-icon-8 = 9;’ŗå
ws-icon-9 = 10;’å░


; Available tags:
;   <label-state> (default) - gets replaced with <label-(focused|unfocused|visible|urgent)>
;   <label-mode> (default)
format = <label-state>

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
; focused = Active workspace on focused monitor
label-focused = %icon% %name%
label-focused-background = ${colors.bground}
label-focused-foreground = ${colors.accent}
label-focused-padding = 2

; Available tokens:
;   %name%
;   %icon%
;   %index%
; Default: %icon%  %name%
; unfocused = Inactive workspace on any monitor
label-unfocused = %icon% %name%
label-unfocused-padding = 2
label-unfocused-background = ${colors.bground}
label-unfocused-foreground = ${colors.modulefg-alt}

; visible = Active workspace on unfocused monitor
label-visible = %icon% %name%
label-visible-background = ${colors.accent}
label-visible-padding = 2

; Available tokens:
;   %name%
;   %icon%
;   %index%
; Default: %icon%  %name%
; urgent = Workspace with urgency hint set
label-urgent = %icon% %name%
label-urgent-background = ${colors.bground}
label-urgent-foreground = ${colors.red}
label-urgent-padding = 2

format-foreground = #000000
format-background = #F07178

[module/backlight]
type = internal/backlight
card = intel_backlight

format = <ramp> <label>
format-background = ${colors.shade4}
format-foreground = ${colors.modulefg}

label = %percentage%%

ramp-0 = ­¤īĢ
ramp-1 = ­¤īö
ramp-2 = ­¤īō
ramp-3 = ­¤īÆ
ramp-4 = ­¤īæ

################################################################################

[module/battery]
;https://github.com/jaagr/polybar/wiki/Module:-battery

type = internal/battery
battery = BAT0
adapter = AC
full-at = 100

poll-interval = 2
time-format = %H:%M

format-charging = <animation-charging> <label-charging>
format-charging-foreground = ${colors.modulefg}
format-charging-background = ${colors.shade5}
format-charging-padding = 1

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-foreground = ${colors.modulefg}
format-discharging-background = ${colors.shade5}
format-discharging-padding = 1

label-charging = %percentage%%
label-discharging = %percentage%%

format-full-prefix = "’ēĆ "
format-full-background = ${colors.shade5}
format-full-foreground = ${colors.modulefg}

format-foreground = ${colors.modulefg}
format-background = ${colors.shade5}

ramp-capacity-0 = ’ēä
ramp-capacity-1 = ’ēā
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ
ramp-capacity-foreground = #fffff

animation-charging-0 = ’ēä
animation-charging-1 = ’ēā
animation-charging-2 = ’ēé
animation-charging-3 = ’ēü
animation-charging-4 = ’ēĆ
animation-charging-foreground = #ffffff
animation-charging-framerate = 750

################################################################################

[module/cpu]
;https://github.com/jaagr/polybar/wiki/Module:-cpu
type = internal/cpu
; Seconds to sleep between updates
; Default: 1
interval = 1
format-foreground = ${colors.modulefg}
format-background = ${colors.shade1}
format-prefix = "’ŗø "

label-font = 1

; Available tags:
;   <label> (default)
;   <bar-load>
;   <ramp-load>
;   <ramp-coreload>
format = <label>


; Available tokens:
;   %percentage% (default) - total cpu load
;   %percentage-cores% - load percentage for each core
;   %percentage-core[1-9]% - load percentage for specific core
label = %percentage:3%%

################################################################################

[module/date]
type = internal/date
interval = 1

time = ’ĆŚ %H:%M
time-alt = ’ü│ %d/%m/%Y%

format = <label>
format-background = ${colors.shade2}
format-foreground = ${colors.modulefg}
format-padding = 1
label = %time%

################################################################################

[module/memory]
;https://github.com/jaagr/polybar/wiki/Module:-memory
type = internal/memory
interval = 1
; Available tokens:
;   %percentage_used% (default)
;   %percentage_free%
;   %gb_used%
;   %gb_free%
;   %gb_total%
;   %mb_used%
;   %mb_free%
;   %mb_total%
label = %percentage_used%%

format = <label>
format-prefix = "’ł│ "
format-foreground = ${colors.modulefg}
format-background = ${colors.shade2}

################################################################################

[module/pavolume]
type = internal/pulseaudio
sink = alsa_output.pci-0000_00_1f.3.analog-stereo
user-ui-max = false

format-volume = <ramp-volume> <label-volume>
format-volume-background = ${colors.shade6}
format-volume-foreground = ${colors.modulefg}
format-volume-padding = 1

label-volume = %percentage%%

format-muted-prefix = ’Ć”’ĆŹ
label-muted = " Muted"
format-muted-background = ${colors.shade6}
format-muted-foreground = ${colors.modulefg}
format-muted-padding = 1

